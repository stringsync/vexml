<?xml version="1.0" encoding="UTF-8" ?>
<score-partwise version="4.0">
  <part-list>
    <score-part id="P1">
      <part-name>Music</part-name>
    </score-part>
  </part-list>
  <part id="P1">
    <!-- Two stem-up half-note chords (C5/E5/G5) with all three members tied to the next
         chord. The bottom member (C5) bows under (concave up) while the upper two (E5, G5)
         bow over (concave down), so the ties sandwich the chord — the over-arcs clearing the
         up-stems rather than tucking under them. -->
    <measure number="1">
      <attributes>
        <divisions>2</divisions>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
        <staves>1</staves>
        <clef>
          <sign>G</sign>
          <line>2</line>
        </clef>
      </attributes>
      <note>
        <pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="start" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="start" /></notations>
      </note>
      <note>
        <chord/>
        <pitch><step>E</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="start" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="start" /></notations>
      </note>
      <note>
        <chord/>
        <pitch><step>G</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="start" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="start" /></notations>
      </note>
      <note>
        <pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="stop" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="stop" /></notations>
      </note>
      <note>
        <chord/>
        <pitch><step>E</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="stop" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="stop" /></notations>
      </note>
      <note>
        <chord/>
        <pitch><step>G</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="stop" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="stop" /></notations>
      </note>
    </measure>
  </part>
</score-partwise>
