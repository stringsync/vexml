      <attributes>
        <divisions>1</divisions>
        <staves>1</staves>
        <staff-details>
          <staff-lines>6</staff-lines>
        </staff-details>
        <clef>
          <sign>TAB</sign>
          <line>5</line>
        </clef>
      </attributes>
      <!-- Adjacent 3-string triad on strings 3/2/1 (frets 0/1/0) — C major. -->
      <note>
        <pitch><step>G</step><octave>3</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations><technical><string>3</string><fret>0</fret></technical></notations>
