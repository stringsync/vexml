<?xml version="1.0" encoding="UTF-8" ?>
<score-partwise version="4.0">
  <part-list>
    <score-part id="P1">
      <part-name>Music</part-name>
    </score-part>
  </part-list>
  <part id="P1">
    <!-- Treble 4/4: natural harmonics drawn as diamond noteheads. Each note carries
         <notations><technical><harmonic><natural/>, which src/notes.ts vexflowKey maps to
         the '/H' notehead code (open diamond for half+/whole, filled for quarter). Stable
         E5 pitch so only the notehead — and its duration-driven fill — varies. -->
    <measure number="1">
      <attributes>
        <divisions>2</divisions>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
        <staves>1</staves>
        <clef>
          <sign>G</sign>
          <line>2</line>
        </clef>
      </attributes>
      <note>
        <pitch><step>E</step><octave>5</octave></pitch>
        <duration>4</duration>
        <type>half</type>
        <notations><technical><harmonic><natural /></harmonic></technical></notations>
      </note>
      <note>
        <pitch><step>E</step><octave>5</octave></pitch>
        <duration>2</duration>
        <type>quarter</type>
        <notations><technical><harmonic><natural /></harmonic></technical></notations>
      </note>
      <note>
        <pitch><step>E</step><octave>5</octave></pitch>
        <duration>2</duration>
        <type>quarter</type>
        <notations><technical><harmonic><natural /></harmonic></technical></notations>
      </note>
    </measure>
  </part>
</score-partwise>
