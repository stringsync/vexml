          <slur number="1" type="start" />
        </notations>
      </note>
      <note>
        <pitch><step>E</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical><string>2</string><fret>5</fret></technical>
          <slur number="1" type="stop" />
        </notations>
      </note>
    </measure>
    <!-- Two-string chords: ascending hammer-on chord then descending pull-off chord.
         The lead string (3) drives the inference for the whole chord. -->
