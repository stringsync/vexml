  <part id="P1">
    <!-- Guitar: a treble notation stave over a 6-line TAB stave, joined by a bracket
         (<part-symbol>bracket</part-symbol>). Deliberately exercises the measure box's
         extremes: an ascending run high above the treble staff (A5/C6/D6/E6, several
         ledger lines up) so the box must grow past its top staff line, plus a C-major
         chord diagram (<harmony> <frame>) above beat 1. The measure-box-bounds test draws
         a debug rect around each measure box and checks the bracket and notes fall inside.
         Voice 1 (staff 1) carries the pitches; voice 2 (staff 2) the same notes as
         string 1 frets: A5 = fret 17, C6 = 20, D6 = 22, E6 = 24. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
        <staves>2</staves>
        <part-symbol>bracket</part-symbol>
        <clef number="1">
          <sign>G</sign>
          <line>2</line>
        </clef>
        <clef number="2">
          <sign>TAB</sign>
          <line>5</line>
        </clef>
        <staff-details number="2">
          <staff-lines>6</staff-lines>
        </staff-details>
      </attributes>
      <harmony>
        <root>
          <root-step>C</root-step>
        </root>
        <kind text="">major</kind>
        <frame>
          <frame-strings>6</frame-strings>
          <frame-frets>4</frame-frets>
          <first-fret>1</first-fret>
          <frame-note><string>5</string><fret>3</fret></frame-note>
          <frame-note><string>4</string><fret>2</fret></frame-note>
          <frame-note><string>3</string><fret>0</fret></frame-note>
          <frame-note><string>2</string><fret>1</fret></frame-note>
          <frame-note><string>1</string><fret>0</fret></frame-note>
        </frame>
      </harmony>
      <note>
        <pitch><step>A</step><octave>5</octave></pitch>
        <duration>1</duration>
        <voice>1</voice>
        <type>quarter</type>
        <staff>1</staff>
      </note>
