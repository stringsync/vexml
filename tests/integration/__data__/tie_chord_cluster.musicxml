  <part id="P1">
    <!-- Spacing variant — a four-note cluster of stacked seconds (C5/D5/E5/F5) where all
         members tie. Every adjacent pair is a second so the noteheads zig-zag across the stem;
         the lower half (C5, D5) bows under and the upper half (E5, F5) bows over, stress-testing
         tie placement under the tightest vertical spacing and offset noteheads. -->
    <measure number="1">
      <attributes>
        <divisions>2</divisions>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
