<?xml version="1.0" encoding="UTF-8" ?>
<score-partwise version="4.0">
  <part-list>
    <score-part id="P1">
      <part-name>Music</part-name>
    </score-part>
  </part-list>
  <part id="P1">
    <!-- 6-line TAB stave. Grace notes draw as small fret numbers just left of their main
         note, reading straight from <notations>. No <time>, so no time signature. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <staves>1</staves>
        <clef>
          <sign>TAB</sign>
          <line>5</line>
        </clef>
        <staff-details>
          <staff-lines>6</staff-lines>
        </staff-details>
      </attributes>
      <!-- A single grace (string 3, fret 7) before its main note (fret 5). -->
      <note>
        <grace />
        <pitch><step>D</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations><technical><string>3</string><fret>7</fret></technical></notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations><technical><string>3</string><fret>5</fret></technical></notations>
      </note>
      <!-- A pair of graces (frets 7, 9) before a main note (fret 5). -->
      <note>
        <grace />
        <pitch><step>D</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations><technical><string>3</string><fret>7</fret></technical></notations>
      </note>
      <note>
        <grace />
        <pitch><step>E</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations><technical><string>3</string><fret>9</fret></technical></notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations><technical><string>3</string><fret>5</fret></technical></notations>
      </note>
    </measure>
    <!-- A grace (string 3, fret 7) slurred to its main note (fret 5) — a slur line
         curves from the small grace fret to the half note. -->
    <measure number="2">
      <note>
        <grace />
        <pitch><step>D</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations>
          <technical><string>3</string><fret>7</fret></technical>
          <slur number="1" type="start" />
        </notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical><string>3</string><fret>5</fret></technical>
          <slur number="1" type="stop" />
        </notations>
      </note>
    </measure>
  </part>
</score-partwise>
