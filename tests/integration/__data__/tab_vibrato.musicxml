  </part-list>
  <part id="P1">
    <!-- 6-line TAB stave. Vibrato is a <wavy-line> in <ornaments>: the squiggle stretches
         to the next note or the bar's end, whichever comes first. No <time>, so no time
         signature. -->
    <!-- The first (string 3, fret 7) runs up to the second note; the second (fret 5) is
         last, so it runs to the bar's end. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <staves>1</staves>
        <clef>
          <sign>TAB</sign>
          <line>5</line>
        </clef>
        <staff-details>
          <staff-lines>6</staff-lines>
        </staff-details>
      </attributes>
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical><string>3</string><fret>7</fret></technical>
          <ornaments><wavy-line type="start" /></ornaments>
        </notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical><string>3</string><fret>5</fret></technical>
          <ornaments><wavy-line type="start" /></ornaments>
        </notations>
      </note>
    </measure>
  </part>
</score-partwise>
