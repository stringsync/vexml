    <!-- Guitar: a treble notation stave over a 6-line TAB stave, joined by a bracket
         (<part-symbol>bracket</part-symbol>) instead of the default brace. An ascending
         line on string 1 proves the fret -> pitch mapping (open string 1 = E4): fret 0 =
         E4, fret 1 = F4, fret 3 = G4, fret 5 = A4. Voice 1 (staff 1) carries the pitches
         for the notation stave; voice 2 (staff 2) carries the same notes as string/fret. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <staves>2</staves>
        <part-symbol>bracket</part-symbol>
        <staff-details number="2">
