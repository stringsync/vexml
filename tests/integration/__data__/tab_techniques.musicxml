<?xml version="1.0" encoding="UTF-8" ?>
<score-partwise version="4.0">
  <part-list>
    <score-part id="P1">
      <part-name>Music</part-name>
    </score-part>
  </part-list>
  <part id="P1">
    <!-- 6-line TAB stave. An advanced companion to tab_hammer_pull.musicxml: grace
         notes plus slides, bends, vibrato, and text annotations. Each technique reads
         straight from <notations> (see src/notes.ts addTabModifiers / src/spanners.ts
         buildSlides). No <time>, so no time signature is drawn. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <staves>1</staves>
        <staff-details>
          <staff-lines>6</staff-lines>
        </staff-details>
        <clef>
          <sign>TAB</sign>
          <line>5</line>
        </clef>
      </attributes>
      <!-- A single grace (string 3, fret 7) before its main note (fret 5). -->
      <note>
        <grace />
        <pitch><step>D</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations><technical><string>3</string><fret>7</fret></technical></notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations><technical><string>3</string><fret>5</fret></technical></notations>
      </note>
      <!-- A pair of graces (frets 7, 9) before a main note (fret 5). -->
      <note>
        <grace />
        <pitch><step>D</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations><technical><string>3</string><fret>7</fret></technical></notations>
      </note>
      <note>
        <grace />
        <pitch><step>E</step><octave>4</octave></pitch>
        <type>16th</type>
        <notations><technical><string>3</string><fret>9</fret></technical></notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations><technical><string>3</string><fret>5</fret></technical></notations>
      </note>
    </measure>
    <!-- Slides: a slide up (string 3, fret 5 -> 7) then a slide down (fret 9 -> 7),
         each a <slide> start/stop pair drawn as a tilted TabSlide line. -->
    <measure number="2">
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical><string>3</string><fret>5</fret></technical>
          <slide number="1" type="start" />
        </notations>
      </note>
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical><string>3</string><fret>7</fret></technical>
          <slide number="1" type="stop" />
        </notations>
      </note>
      <note>
        <pitch><step>E</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical><string>3</string><fret>9</fret></technical>
          <slide number="2" type="start" />
        </notations>
      </note>
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical><string>3</string><fret>7</fret></technical>
          <slide number="2" type="stop" />
        </notations>
      </note>
    </measure>
    <!-- Bends: a whole-step bend ("full", bend-alter 2) on string 3, then a half-step
         bend ("½", bend-alter 1) on string 2. Each draws an upward arrow + label. -->
    <measure number="3">
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical>
            <string>3</string><fret>7</fret>
            <bend><bend-alter>2</bend-alter></bend>
          </technical>
        </notations>
      </note>
      <note>
        <pitch><step>E</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical>
            <string>2</string><fret>5</fret>
            <bend><bend-alter>1</bend-alter></bend>
          </technical>
        </notations>
      </note>
    </measure>
    <!-- Bend and release on string 3, fret 7: bend up "full" then release back, drawn
         as an up-then-down arrow (the <release/> child adds the return leg). -->
    <measure number="4">
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>4</duration>
        <type>whole</type>
        <notations>
          <technical>
            <string>3</string><fret>7</fret>
            <bend><bend-alter>2</bend-alter><release /></bend>
          </technical>
        </notations>
      </note>
    </measure>
    <!-- Vibrato via a <wavy-line> in <ornaments>: the squiggle stretches to the next
         note or the bar's end, whichever comes first. The first (string 3, fret 7) runs
         up to the second note; the second (fret 5) is last, so it runs to the bar's end. -->
    <measure number="5">
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical><string>3</string><fret>7</fret></technical>
          <ornaments><wavy-line type="start" /></ornaments>
        </notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical><string>3</string><fret>5</fret></technical>
          <ornaments><wavy-line type="start" /></ornaments>
        </notations>
      </note>
    </measure>
    <!-- A natural harmonic, drawn as its fret in angle brackets ("<12>", from <harmonic>),
         then text annotations above the frets: a palm mute ("P.M.") and a dead note ("x"),
         both via <other-technical>, then a plain note for contrast. -->
    <measure number="6">
      <note>
        <pitch><step>B</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical>
            <string>3</string><fret>12</fret>
            <harmonic><natural /></harmonic>
          </technical>
        </notations>
      </note>
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical>
            <string>3</string><fret>7</fret>
            <other-technical>P.M.</other-technical>
          </technical>
        </notations>
      </note>
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations>
          <technical>
            <string>3</string><fret>7</fret>
            <other-technical>x</other-technical>
          </technical>
        </notations>
      </note>
      <note>
        <pitch><step>C</step><octave>4</octave></pitch>
        <duration>1</duration>
        <type>quarter</type>
        <notations><technical><string>3</string><fret>5</fret></technical></notations>
      </note>
    </measure>
  </part>
</score-partwise>
