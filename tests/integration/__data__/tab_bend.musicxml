<?xml version="1.0" encoding="UTF-8" ?>
<score-partwise version="4.0">
  <part-list>
    <score-part id="P1">
      <part-name>Music</part-name>
    </score-part>
  </part-list>
  <part id="P1">
    <!-- 6-line TAB stave. Bends read from <bend> in <technical>, each drawn as an upward
         arrow + label. No <time>, so no time signature is drawn. -->
    <!-- A whole-step bend ("full", bend-alter 2) on string 3, then a half-step bend
         ("½", bend-alter 1) on string 2. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <staves>1</staves>
        <clef>
          <sign>TAB</sign>
          <line>5</line>
        </clef>
        <staff-details>
          <staff-lines>6</staff-lines>
        </staff-details>
      </attributes>
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical>
            <string>3</string><fret>7</fret>
            <bend><bend-alter>2</bend-alter></bend>
          </technical>
        </notations>
      </note>
      <note>
        <pitch><step>E</step><octave>4</octave></pitch>
        <duration>2</duration>
        <type>half</type>
        <notations>
          <technical>
            <string>2</string><fret>5</fret>
            <bend><bend-alter>1</bend-alter></bend>
          </technical>
        </notations>
      </note>
    </measure>
    <!-- Bend and release on string 3, fret 7: bend up "full" then release back, drawn
         as an up-then-down arrow (the <release/> child adds the return leg). -->
    <measure number="2">
      <note>
        <pitch><step>D</step><octave>4</octave></pitch>
        <duration>4</duration>
        <type>whole</type>
        <notations>
          <technical>
            <string>3</string><fret>7</fret>
            <bend><bend-alter>2</bend-alter><release /></bend>
          </technical>
        </notations>
      </note>
    </measure>
  </part>
</score-partwise>
