      </note>
      <note>
        <chord/>
        <pitch><step>G</step><octave>5</octave></pitch>
        <duration>4</duration>
        <tie type="start" />
        <type>half</type>
        <stem>up</stem>
        <notations><tied type="start" /></notations>
