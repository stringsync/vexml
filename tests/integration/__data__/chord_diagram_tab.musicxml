  <part id="P1">
    <!-- A treble notation stave over a 6-line TAB stave (joined by a bracket), with a C-major
         chord diagram (a <harmony> <frame>) floating above beat 1. Voice 1 (staff 1) carries
         the pitches; voice 2 (staff 2) carries the same notes as string/fret. Used by the
         cursor test: the playback bar must stop at the stave top, not rise up to the diagram. -->
    <measure number="1">
      <attributes>
        <divisions>1</divisions>
        <time>
          <beats>4</beats>
          <beat-type>4</beat-type>
        </time>
        <staves>2</staves>
