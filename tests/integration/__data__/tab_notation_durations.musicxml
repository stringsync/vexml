        <clef number="2"><sign>TAB</sign><line>5</line></clef>
        <staff-details number="2"><staff-lines>6</staff-lines></staff-details>
      </attributes>
      <!-- Single dots: dotted-quarter + eighth pairs (6+2+6+2). -->
