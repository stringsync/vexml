    <measure number="3">
      <!-- Triplet: an eighth-note triplet (3:2) then a dotted half. The tuplet's
           time-modification must scale the TAB frets the same way as the noteheads so the
           three frets stay aligned under the three triplet noteheads. divisions=12. -->
      <attributes><divisions>12</divisions></attributes>
      <note>
        <pitch><step>E</step><octave>4</octave></pitch>
        <duration>4</duration><voice>1</voice><type>eighth</type>
        <time-modification><actual-notes>3</actual-notes><normal-notes>2</normal-notes></time-modification>
        <staff>1</staff><beam number="1">begin</beam>
        <notations><tuplet number="1" type="start" /></notations>
      </note>
      <note>
