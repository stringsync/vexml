        <notations><technical><string>2</string><fret>5</fret></technical></notations>
      </note>
    </measure>
    <measure number="4">
      <!-- Triplet that opens on a held (tied-into) note — measure 25 of the jazz corpus.
           Beat 1 is an eighth + tied eighth (F4); the tie carries into the triplet's first
           note, so guitar-tab convention omits that fret (no re-strike). The omitted note
           still owns the triplet's opening slot, so the two struck frets after it (G4, A4)
           must compress under their triplet noteheads instead of drifting right. divisions=12. -->
      <note>
        <pitch><step>E</step><octave>4</octave></pitch>
        <duration>6</duration><voice>1</voice><type>eighth</type><staff>1</staff>
        <beam number="1">begin</beam>
      </note>
      <note>
        <pitch><step>F</step><octave>4</octave></pitch>
        <duration>6</duration><tie type="start" /><voice>1</voice><type>eighth</type>
        <staff>1</staff><beam number="1">end</beam>
        <notations><tied type="start" /></notations>
      </note>
      <note>
        <pitch><step>F</step><octave>4</octave></pitch>
        <duration>4</duration><tie type="stop" /><voice>1</voice><type>eighth</type>
